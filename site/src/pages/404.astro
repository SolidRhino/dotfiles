---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: '404 — Page not found' }}>
  <div style="text-align:center;padding:3rem 0">
    <p style="font-size:4rem;font-weight:800;color:var(--sl-color-gray-4);margin:0">404</p>
    <p style="margin-top:0.5rem">This page doesn't exist.</p>
    <a href="/dotfiles/" style="display:inline-block;margin-top:1.5rem;padding:0.5rem 1.25rem;background:var(--sl-color-accent);color:var(--sl-color-black);border-radius:0.375rem;font-weight:600;text-decoration:none">← Back to docs</a>
  </div>
</StarlightPage>
