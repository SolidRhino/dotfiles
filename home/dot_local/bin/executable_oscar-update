#!/bin/bash
set -eufo pipefail

OSCAR_URL="https://www.sleepfiles.com/OSCAR/"
OSCAR_APP="/Applications/OSCAR.app"
PLIST="$OSCAR_APP/Contents/Info.plist"

# Scrape the latest version from the directory listing
LATEST=$(curl -fsSL "$OSCAR_URL" | grep -oE '/OSCAR/[0-9]+\.[0-9]+\.[0-9]+/' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | sort -V | tail -1)

if [[ -z "$LATEST" ]]; then
  echo "Error: could not determine latest OSCAR version." >&2
  exit 1
fi

# Read installed version (empty string if not installed)
if [[ -f "$PLIST" ]]; then
  INSTALLED=$(defaults read "$PLIST" CFBundleShortVersionString 2>/dev/null || echo "")
else
  INSTALLED=""
fi

if [[ "$INSTALLED" == "$LATEST" ]]; then
  echo "OSCAR $LATEST is already installed. Nothing to do."
  exit 0
fi

if [[ -z "$INSTALLED" ]]; then
  echo "Installing OSCAR $LATEST..."
else
  echo "Upgrading OSCAR from $INSTALLED to $LATEST..."
fi

# Detect architecture
ARCH=$(uname -m)
if [[ "$ARCH" == "arm64" ]]; then
  ARCH_LABEL="AppleSilicon"
elif [[ "$ARCH" == "x86_64" ]]; then
  ARCH_LABEL="Intel"
else
  echo "Error: unsupported architecture: $ARCH" >&2
  exit 1
fi

DMG_NAME="OSCAR-${LATEST}-${ARCH_LABEL}.dmg"
DMG_URL="${OSCAR_URL}${LATEST}/${DMG_NAME}"

# Create temp working directory; clean it up (and detach any mount) on exit
WORK_DIR=$(mktemp -d)
MOUNT="$WORK_DIR/mount"
trap 'hdiutil detach "$MOUNT" -quiet 2>/dev/null || true; rm -rf "$WORK_DIR"' EXIT

STAGED_APP="$WORK_DIR/OSCAR.app"
TARGET_TMP="/Applications/OSCAR.app.new"
BACKUP_APP="/Applications/OSCAR.app.backup"

mkdir -p "$MOUNT"

echo "Downloading $DMG_URL..."
curl --fail --silent --show-error --location --retry 3 --retry-all-errors \
  -o "$WORK_DIR/$DMG_NAME" "$DMG_URL"

echo "Mounting disk image..."
hdiutil attach -nobrowse -quiet -mountpoint "$MOUNT" "$WORK_DIR/$DMG_NAME"

# Stage app from disk image before touching the installed copy
if [[ ! -d "$MOUNT/OSCAR.app" ]]; then
  echo "Error: OSCAR.app not found in mounted disk image" >&2
  exit 1
fi

echo "Staging OSCAR.app..."
ditto "$MOUNT/OSCAR.app" "$STAGED_APP"

echo "Detaching disk image..."
hdiutil detach "$MOUNT" -quiet

echo "Removing quarantine attribute from staged app..."
xattr -dr com.apple.quarantine "$STAGED_APP"

echo "Re-signing staged app (original DMG signature is invalid)..."
codesign --force --deep --sign - "$STAGED_APP"

echo "Preparing replacement app bundle..."
rm -rf "$TARGET_TMP"
ditto "$STAGED_APP" "$TARGET_TMP"

if [[ -d "$OSCAR_APP" ]]; then
  echo "Backing up existing OSCAR.app..."
  rm -rf "$BACKUP_APP"
  mv "$OSCAR_APP" "$BACKUP_APP"
fi

echo "Installing OSCAR.app..."
if mv "$TARGET_TMP" "$OSCAR_APP"; then
  rm -rf "$BACKUP_APP"
else
  echo "Error: failed to install OSCAR.app" >&2
  rm -rf "$TARGET_TMP"
  if [[ -d "$BACKUP_APP" ]]; then
    mv "$BACKUP_APP" "$OSCAR_APP"
  fi
  exit 1
fi

echo "OSCAR $LATEST installed successfully."
