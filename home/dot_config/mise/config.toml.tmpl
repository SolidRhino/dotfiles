[settings.ruby]
compile = false

# Versioning policy:
# - Use "latest" for fast-moving developer tooling where staying current matters more than pin stability.
# - Use "lts" for runtimes with broad ecosystem support windows.
# - Use a major version when tracking the newest stable line without churn from full version pins.
[tools]
go = "latest"
node = "lts"
ruby = "4"
uv = "latest"
python = "latest"
bun = "latest"
{{- if eq .chezmoi.os "darwin" }}
"npm:@smithery/cli" = "latest"
"npm:bash-language-server" = "latest"
"npm:fish-lsp" = "latest"
"npm:pyright" = "latest"
"npm:typescript" = "latest"
"npm:typescript-language-server" = "latest"
"npm:vscode-langservers-extracted" = "latest"
"npm:yaml-language-server" = "latest"
"gem:ruby-lsp" = "latest"
"go:golang.org/x/tools/gopls" = "latest"
{{- end }}
