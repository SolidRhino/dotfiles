{
  "$schema": "https://opencode.ai/config.json",

  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.4-mini",
  // "default_agent" is the correct schema key (snake_case per opencode.ai/config.json — not camelCase).
  "default_agent": "code",

  "autoupdate": "notify",
  "share": "disabled",

  // === Snapshots (rollback safety net) ===
  "snapshot": true,

  "agent": {
    "plan": {
      "model": "openai/gpt-5.4"
    },
    "build": {
      "disable": true
    }
  },

  "disabled_providers": [
    "ollama-cloud",
    "openrouter",
    "google"
  ],

  "watcher": {
    "ignore": [
      "node_modules",
      "vendor",
      ".git",
      "storage",
      "bootstrap/cache",
      ".serena/cache"
    ]
  },

  // === Permissions ===
  "permission": {
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git checkout *": "allow",
      "git branch *": "allow",
      "git stash *": "allow",
      "git pull *": "allow",
      "git push": "allow",
      "git fetch *": "allow",
      "git show *": "allow",
      "npm install *": "allow",
      "npm run *": "allow",
      "npm test *": "allow",
      "npm ci": "allow",
      "npm list *": "allow",
      "npx prettier *": "allow",
      "npx tsc *": "allow",
      "npx phpstan *": "allow",
      "npx php-cs-fixer *": "allow",
      "node *": "allow",
      "bun *": "allow",
      "ls *": "allow",
      "cat *": "ask",
      "find *": "ask",
      "grep *": "ask"
    },
    "edit": {
      "*": "allow",
      "**/.env*": "deny"
    },
    "task": "allow",
    "external_directory": "ask",
    "doom_loop": "ask"
  },

  // === Instructions ===
  "instructions": [
    ".opencode/instructions.md",
    "plugins/shell-strategy/shell_strategy.md"
  ],

  // === Formatters ===
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [
        "ts", "tsx", "js", "jsx",
        "json", "jsonc",
        "css", "scss", "less",
        "md", "mdx",
        "html",
        "yaml", "yml",
        "graphql", "gql",
        "xml", "svg"
      ]
    },
    "pint": {
      "command": ["./vendor/bin/pint", "$FILE"],
      "extensions": ["php"]
    },
    "prettier-blade": {
      "command": [
        "npx", "-y", "-p", "prettier", "-p", "@shufo/prettier-plugin-blade",
        "prettier", "--plugin", "@shufo/prettier-plugin-blade", "--write", "$FILE"
      ],
      "extensions": ["blade.php"]
    },
    "tailwind-sort": {
      "command": [
        "npx", "-y", "-p", "prettier", "-p", "prettier-plugin-tailwindcss",
        "prettier", "--plugin", "prettier-plugin-tailwindcss", "--write", "$FILE"
      ],
      "extensions": ["blade.php", "html", "jsx", "tsx", "vue"]
    }
  },

  // === Plugins ===
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-vibeguard@latest",
    "cc-safety-net@latest",
    "opencode-snip@latest",
    "opencode-pty@latest",
    "@mohak34/opencode-notifier@latest",
    "@plannotator/opencode@latest",
    "opencode-agent-memory@0.2.0",
    "opencode-worktree@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-claude-auth@latest"
  ],

  // === MCP Servers ===
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx", "--from", "git+https://github.com/oraios/serena",
        "serena", "start-mcp-server", "--project-from-cwd"
      ]
    },
    "nixos": {
      "type": "local",
      "command": ["uvx", "mcp-nixos"]
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "git": {
      "type": "local",
      // Use sh so $HOME expands at runtime; keeps this path portable across machines.
      "command": ["sh", "-lc", "bun \"$HOME/.config/opencode/scripts/git-mcp-wrapper.ts\""]
    },
    "grep-app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },

  // === LSP Servers ===
  "lsp": {
    "fish-lsp": {
      "command": [
        "fish-lsp",
        "start"
      ],
      "extensions": [
        ".fish"
      ]
    },
    "taplo": {
      "command": [
        "taplo",
        "lsp",
        "stdio"
      ],
      "extensions": [
        ".toml"
      ]
    },
    "vscode-json-language-server": {
      "command": [
        "vscode-json-language-server",
        "--stdio"
      ],
      "extensions": [
        ".json",
        ".jsonc"
      ]
    },
    "marksman": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md",
        ".markdown"
      ]
    }
  }
}
