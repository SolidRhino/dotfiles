{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -eufo pipefail

SUDO_LOCAL="/etc/pam.d/sudo_local"

PAM_REATTACH="$(brew --prefix)/lib/pam/pam_reattach.so"

if [ ! -f "$PAM_REATTACH" ]; then
    echo "Error: pam_reattach.so not found at $PAM_REATTACH" >&2
    echo "Install it with: brew install pam-reattach" >&2
    exit 1
fi

EXPECTED="# sudo_local: local config file which survives system update and is included for sudo
auth       optional       ${PAM_REATTACH}
auth       sufficient     pam_tid.so"

if [ -f "$SUDO_LOCAL" ] && [ "$(cat "$SUDO_LOCAL")" = "$EXPECTED" ]; then
    exit 0
fi

echo "$EXPECTED" | sudo tee "$SUDO_LOCAL" > /dev/null
{{ end -}}
