#!/bin/sh

# Extract encrypted archive after chezmoi apply
# The archive is decrypted by chezmoi, then this script extracts it
# Only extracts if a JetBrains product is installed; removes the archive otherwise

set -e

ARCHIVE_PATH="${HOME}/.local/share/x7k9m2p.tar.gz"
EXTRACT_PATH="${HOME}/.local/share/x7k9m2p"

# Skip entirely if no archive was decrypted
[ -f "${ARCHIVE_PATH}" ] || exit 0

# Detect JetBrains installation (macOS: ~/Library/Application Support/JetBrains, Linux: ~/.config/JetBrains)
JETBRAINS_FOUND=false
if [ -d "${HOME}/Library/Application Support/JetBrains" ] && \
   ls "${HOME}/Library/Application Support/JetBrains" | grep -q .; then
    JETBRAINS_FOUND=true
elif [ -d "${HOME}/.config/JetBrains" ] && \
     ls "${HOME}/.config/JetBrains" | grep -q .; then
    JETBRAINS_FOUND=true
fi

if [ "${JETBRAINS_FOUND}" = "false" ]; then
    exit 0
fi

rm -rf "${EXTRACT_PATH}"
mkdir -p "${EXTRACT_PATH}"
tar -xzf "${ARCHIVE_PATH}" -C "${EXTRACT_PATH}" --strip-components=1
