{{ if not .ephemeral -}}
#!/bin/bash
set -eufo pipefail

# Packages: {{ .packages.cargo | join ", " }}

if ! command -v cargo >/dev/null 2>&1; then
    # shellcheck source=/dev/null
    source "$HOME/.cargo/env"
fi

if ! command -v cargo >/dev/null 2>&1; then
    echo "Error: cargo not found even after sourcing ~/.cargo/env" >&2
    exit 1
fi

{{ range .packages.cargo -}}
cargo install --locked {{ . }}
{{ end -}}
{{ end -}}
