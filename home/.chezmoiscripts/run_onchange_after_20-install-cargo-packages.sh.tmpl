{{ if not .ephemeral -}}
#!/bin/bash
set -eufo pipefail

# Packages: {{ .packages.cargo | join ", " }}

if ! command -v cargo >/dev/null 2>&1; then
    # shellcheck source=/dev/null
    source "$HOME/.cargo/env"
fi

if ! command -v cargo >/dev/null 2>&1; then
    echo "Error: cargo not found even after sourcing ~/.cargo/env" >&2
    exit 1
fi

package_installed() {
    local package="$1"

    cargo install --list | grep -Fq "${package} v"
}

install_cargo_package() {
    local package="$1"

    if package_installed "$package"; then
        echo "$package: already installed, skipping"
        return 0
    fi

    if [ "$package" != "cargo-binstall" ] && command -v cargo-binstall >/dev/null 2>&1; then
        cargo binstall --no-confirm --locked "$package"
    else
        cargo install --locked "$package"
    fi
}

{{ range .packages.cargo -}}
install_cargo_package {{ . }}
{{ end -}}
{{ end -}}
